ADAPTIVE_AGENT_LLM=ollama
OLLAMA_MODEL=qwen3.5:2b
ADAPTIVE_AGENT_WORKSPACE=.
ADAPTIVE_AGENT_MAX_SELF_CORRECTIONS=2

# Optional cloud providers (see llm_test.py)
OPENAI_API_KEY=
# OpenAI 나노·미니 (USD/1M; 합산=Input+Output 비캐시) — 저렴한 순
# OPENAI_MODEL=gpt-5-nano      # $0.05 in / $0.005 cached / $0.40 out → 합 $0.45 (기본)
# OPENAI_MODEL=gpt-4.1-nano    # $0.10 / $0.025 / $0.40 → 합 $0.50
# OPENAI_MODEL=gpt-4o-mini     # $0.15 / $0.075 / $0.60 → 합 $0.75
# OPENAI_MODEL=gpt-3.5-turbo

GEMINI_API_KEY=
# Google AI Studio(Gemini Developer API) API 키 — 이 경로는 GCP Project ID 없이 동작합니다.
# Vertex AI를 쓸 때만 project/location이 필요하며, 현재 코드는 API 키 경로만 지원합니다.
# GOOGLE_API_KEY만 있어도 인식합니다(둘 다 있으면 문서상 GOOGLE_API_KEY가 우선될 수 있음).
# 저가·GA 권장 기본: gemini-2.5-flash-lite (구 2.0 Flash-Lite 대체)
