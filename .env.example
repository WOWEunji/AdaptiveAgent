# AdaptiveAgent 환경 설정 템플릿
# 사용법: cp .env.example .env  →  .env에 실제 키 입력
# .env는 Git에 커밋하지 않는다 (.gitignore에 포함되어 있음)

# ─────────────────────────────────────────────
#  LLM Provider 선택 (ollama | openai | openrouter)
# ─────────────────────────────────────────────
ADAPTIVE_AGENT_LLM=ollama

# ─────────────────────────────────────────────
#  Ollama (로컬 실행, 인터넷 불필요)
#  권장: qwen3.5:9b 이상 (9b 미만은 Coder 단계 실패율 높음)
# ─────────────────────────────────────────────
OLLAMA_MODEL=qwen3.5:9b          # 권장 최소 — 로컬 고품질
# OLLAMA_MODEL=qwen3.5:2b        # 경량 테스트용 (Coder 단계 실패 가능)
# OLLAMA_MODEL=qwen3.5:4b        # 경량 테스트용 (Coder 단계 실패 가능)
# OLLAMA_MODEL=qwen3.5:14b       # 고품질
# OLLAMA_MODEL=qwen3.5:27b       # 최고 품질 (VRAM 요구 높음)
# OLLAMA_MODEL=qwen2.5-coder:7b  # 코드 특화 — Coder 단계 품질 향상
OLLAMA_PORT=11434
OLLAMA_TIMEOUT_SECONDS=120

# ─────────────────────────────────────────────
#  OpenAI API
#  권장: gpt-5.4-mini 이상 (nano도 동작하나 mini 이상 권장)
# ─────────────────────────────────────────────
# ADAPTIVE_AGENT_LLM=openai
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-5.4-mini        # 권장 최소 — AAVS 8/8 통과
# OPENAI_MODEL=gpt-5.4-nano      # 경량 (AAVS 8/8, 비용 절감)
# OPENAI_MODEL=gpt-4.1-mini      # 안정적
# OPENAI_MODEL=gpt-4.1-nano      # 경량
# OPENAI_MODEL=gpt-4o-mini       # 범용

# ─────────────────────────────────────────────
#  OpenRouter API (다양한 무료 모델 지원)
#  권장: 9B 파라미터 이상 모델
#  ⚠ 무료 플랜 일일 사용 한도: 약 50회 요청 — 초과 시 오류 발생
# ─────────────────────────────────────────────
# ADAPTIVE_AGENT_LLM=openrouter
OPENROUTER_API_KEY=<your-openrouter-api-key>
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free       # 권장 최소 (9B)
# OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free # 30B, 고품질
# OPENROUTER_MODEL=openai/gpt-oss-120b:free            # 120B, 최고 품질
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free # 120B, 고품질

# ─────────────────────────────────────────────
#  응답 언어 설정
#  Synthesizer(자연어 요약)가 이 언어로 최종 답변을 출력한다
#  예: ko (한국어) | en (영어) | ja (일본어)
# ─────────────────────────────────────────────
ADAPTIVE_AGENT_LANGUAGE=ko

# ─────────────────────────────────────────────
#  Self-Correction 최대 재시도 횟수
#  코드 실행 실패 시 LLM이 오류를 분석해 코드를 수정하는 횟수
#  총 실행 횟수 = 1(최초) + N(수정) → 기본값 3이면 최대 4회 실행
#  값이 클수록 복잡한 태스크 성공률이 높아지나 API 호출 비용 증가
# ─────────────────────────────────────────────
ADAPTIVE_AGENT_MAX_SELF_CORRECTIONS=2

# ─────────────────────────────────────────────
#  사용자 작업 공간 고정 (선택)
#  스킬 라이브러리·세션·로그가 저장될 경로
#  미설정 시 --workspace 옵션으로 실행마다 지정
# ─────────────────────────────────────────────
# ADAPTIVE_AGENT_WORKSPACE=/home/alice/my-workspace
